---
import Layout from "@layouts/Layout.astro";
import { getNewsItems } from "@data/news";
import { getLocaleFromUrl, getLocalizedPath, useTranslations } from "@i18n/utils";

const lang = getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);
const posts = getNewsItems(lang);
---

<Layout>
  <main class="bg-site-gray min-h-screen">
    <section class="bg-white py-16 max-sm:py-12" aria-labelledby="news-title">
      <div class="mx-auto w-[min(1120px,calc(100%_-_20px))] max-sm:w-[calc(100%_-_32px)]">
        <span class="bg-gold mb-8 block h-0.5 w-[70px]"></span>
        <h1
          id="news-title"
          class="font-display text-church-green m-0 text-[clamp(42px,5vw,72px)] leading-none font-bold tracking-normal uppercase">
          {t("news.title")}
        </h1>
        <p class="mt-5 mb-0 max-w-[720px] text-xl leading-8 text-neutral-600">{t("news.subtitle")}</p>
      </div>
    </section>

    <section class="py-16 max-sm:py-10">
      <div
        class="mx-auto grid w-[min(1090px,calc(100%_-_20px))] grid-cols-3 gap-[42px] max-lg:grid-cols-1 max-sm:w-[calc(100%_-_32px)]">
        {
          posts.map((post) => (
            <article class="min-w-0 bg-white shadow-[0_0_0_1px_#dedede]">
              <a class="block no-underline" href={getLocalizedPath(`/news/${post.id}`, lang)} aria-label={post.title}>
                <div class={`post-image h-[220px] overflow-hidden ${post.imageClass}`} aria-hidden="true">
                  <span />
                </div>
              </a>
              <div class="px-5 pt-7 pb-8">
                <h2 class="font-display text-church-green mb-5 text-[30px] leading-[1.07] font-bold tracking-normal">
                  <a class="text-inherit no-underline" href={getLocalizedPath(`/news/${post.id}`, lang)}>
                    {post.title}
                  </a>
                </h2>
                <time class="mb-3.5 block text-lg text-neutral-500">{post.date}</time>
                <p class="m-0 text-[19px] leading-[1.55] text-neutral-500">{post.excerpt}</p>
                <a
                  class="text-church-green mt-5 inline-block text-base font-bold no-underline"
                  href={getLocalizedPath(`/news/${post.id}`, lang)}>
                  {t("news.readMore")}
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</Layout>
