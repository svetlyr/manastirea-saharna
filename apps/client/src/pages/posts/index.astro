---
import Pagination from "@components/Pagination.astro";
import PostCard from "@components/PostCard.astro";
import { getPaginatedPosts, getPublishedPosts, getTotalPostPages } from "@data/posts";
import Layout from "@layouts/Layout.astro";
import { getLocaleFromUrl, useTranslations } from "@i18n/utils";

const lang = getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);
const allPosts = await getPublishedPosts(lang);
const posts = getPaginatedPosts(allPosts, 1);
const totalPages = getTotalPostPages(allPosts.length);
---

<Layout>
  <main class="bg-site-gray min-h-screen">
    <section class="bg-white py-16 max-sm:py-12" aria-labelledby="posts-title">
      <div class="mx-auto w-[min(1120px,calc(100%_-_20px))] max-sm:w-[calc(100%_-_32px)]">
        <span class="bg-gold mb-8 block h-0.5 w-[70px]"></span>
        <h1
          id="posts-title"
          class="font-display text-church-green m-0 text-[clamp(42px,5vw,72px)] leading-none font-bold tracking-normal uppercase">
          {t("news.title")}
        </h1>
        <p class="mt-5 mb-0 max-w-[720px] text-xl leading-8 text-neutral-600">{t("news.subtitle")}</p>
      </div>
    </section>

    {
      posts.length > 0 && (
        <section class="py-16 max-sm:py-10">
          <div class="mx-auto grid w-[min(1090px,calc(100%_-_20px))] grid-cols-3 gap-[42px] max-lg:grid-cols-1 max-sm:w-[calc(100%_-_32px)]">
            {posts.map((post) => <PostCard post={post} lang={lang} />)}
          </div>

          <Pagination currentPage={1} totalPages={totalPages} lang={lang} />
        </section>
      )
    }
  </main>
</Layout>
