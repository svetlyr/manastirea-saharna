---
import Layout from "@layouts/Layout.astro";
import { getLocaleFromUrl, useTranslations } from "@i18n/utils";

const lang = getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);

const bankDetails = [
  t("donations.monastery"),
  t("donations.bank"),
  t("donations.fiscalCode"),
  t("donations.bankCode"),
  t("donations.iban"),
  t("donations.address"),
  t("donations.country"),
];
---

<Layout>
  <main class="bg-site-gray min-h-screen">
    <section class="flex min-h-[calc(100vh_-_116px)] items-center py-16 max-sm:py-10" aria-labelledby="donations-title">
      <div class="mx-auto w-[min(860px,calc(100%_-_20px))] max-sm:w-[calc(100%_-_32px)]">
        <span class="bg-gold mb-8 block h-0.5 w-[70px]"></span>
        <article class="bg-white p-7 shadow-[0_0_0_1px_#dedede] md:p-10">
          <h1
            id="donations-title"
            class="font-display text-church-green m-0 text-center text-[clamp(42px,5vw,72px)] leading-none font-bold tracking-normal uppercase">
            {t("donations.title")}
          </h1>

          <div class="mt-9 grid gap-5 text-[19px] leading-8 text-neutral-600">
            <p class="m-0 text-xl font-bold text-neutral-800">{t("donations.greeting")}</p>
            <p class="m-0">{t("donations.message")}</p>
            <p class="m-0">{t("donations.detailsIntro")}</p>
            <p class="m-0 font-bold text-neutral-800">{t("donations.bankNote")}</p>
          </div>

          <section class="mt-8 rounded-md border border-neutral-200 bg-neutral-50 p-5">
            <h2 class="font-display text-church-green mt-0 mb-5 text-[30px] leading-none font-bold">
              {t("donations.bankDetailsTitle")}
            </h2>
            <ul class="m-0 grid list-none gap-2 p-0 text-base leading-7 text-neutral-700">
              {bankDetails.map((detail) => <li>{detail}</li>)}
            </ul>
          </section>

          <a
            class="bg-church-green mt-8 inline-flex min-h-12 items-center justify-center rounded-md px-7 font-bold text-white no-underline shadow-[0_12px_24px_rgb(8_115_61_/_22%)] transition hover:bg-[#065f32]"
            href="https://paypal.me/iuvenalie">
            {t("donations.paypalLabel")}
            {t("donations.paypalValue")}
          </a>
        </article>
      </div>
    </section>
  </main>
</Layout>
