---
import { useTranslations } from "@i18n/utils";
import type { Locale } from "@i18n";

type Props = {
  idPrefix: string;
  lang: Locale;
  compact?: boolean;
};

const { idPrefix, lang, compact = false } = Astro.props;
const t = useTranslations(lang);
const web3FormsAccessKey = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY;
const formAction = web3FormsAccessKey ? "https://api.web3forms.com/submit" : "#";
const redirectUrl = `${Astro.url.origin}${Astro.url.pathname}#pomelnic-form`;

const inputClass =
  "mt-2 w-full rounded-md border border-neutral-200 bg-white px-4 py-3 text-base text-neutral-900 shadow-sm outline-none transition focus:border-church-green focus:ring-4 focus:ring-church-green/15";
const labelClass = "block text-sm font-bold text-neutral-800";
const textareaClass = `${inputClass} max-h-[280px] min-h-[150px] resize-y`;
---

<form class={compact ? "grid gap-4" : "grid gap-5"} action={formAction} method="post">
  {web3FormsAccessKey && <input type="hidden" name="access_key" value={web3FormsAccessKey} />}
  <input type="hidden" name="subject" value="Pomelnic nou de pe manastirea-saharna.md" />
  <input type="hidden" name="from_name" value="Mănăstirea Saharna" />
  <input type="hidden" name="redirect" value={redirectUrl} />
  <input class="hidden" type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" />

  <div class={compact ? "grid gap-4" : "grid gap-5 md:grid-cols-2"}>
    <label class={labelClass} for={`${idPrefix}-name`}>
      {t("pomelnic.name")}
      <span class="text-[#b42318]">*</span>
      {!compact && <span class="block pt-1 text-xs font-normal text-neutral-500">{t("pomelnic.nameHelp")}</span>}
      <input class={inputClass} id={`${idPrefix}-name`} name="name" type="text" autocomplete="name" required />
    </label>

    <label class={labelClass} for={`${idPrefix}-email`}>
      {t("pomelnic.email")}
      <span class="text-[#b42318]">*</span>
      <span class="block pt-1 text-xs font-normal text-neutral-500">{t("pomelnic.emailHelp")}</span>
      <input class={inputClass} id={`${idPrefix}-email`} name="email" type="email" autocomplete="email" required />
    </label>
  </div>

  <div class={compact ? "grid gap-4" : "grid gap-5 md:grid-cols-2"}>
    <label class={labelClass} for={`${idPrefix}-living`}>
      {t("pomelnic.living")}
      <textarea
        class={textareaClass}
        id={`${idPrefix}-living`}
        name="living_names"
        placeholder={t("pomelnic.livingPlaceholder")}></textarea>
    </label>

    <label class={labelClass} for={`${idPrefix}-departed`}>
      {t("pomelnic.departed")}
      <textarea
        class={textareaClass}
        id={`${idPrefix}-departed`}
        name="departed_names"
        placeholder={t("pomelnic.departedPlaceholder")}></textarea>
    </label>
  </div>

  <label class={labelClass} for={`${idPrefix}-message`}>
    {t("pomelnic.message")}
    <textarea
      class={`${textareaClass} min-h-[130px]`}
      id={`${idPrefix}-message`}
      name="message"
      placeholder={t("pomelnic.messagePlaceholder")}></textarea>
  </label>

  <div class="flex flex-wrap items-center justify-between gap-4 pt-1">
    <p class="m-0 max-w-[520px] text-sm leading-6 text-neutral-500">
      {t("pomelnic.requiredHelp")}
    </p>
    <button
      class="bg-church-green focus:ring-church-green/20 inline-flex min-h-12 cursor-pointer items-center justify-center rounded-md px-7 font-bold text-white shadow-[0_12px_24px_rgb(8_115_61_/_22%)] transition hover:bg-[#065f32] focus:ring-4 focus:outline-none"
      type="submit">
      {t("pomelnic.submit")}
    </button>
  </div>
</form>
