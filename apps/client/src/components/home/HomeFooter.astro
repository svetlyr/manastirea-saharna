---
import type { Locale } from "@i18n";
import { useTranslations } from "@i18n/utils";

type Props = {
  lang: Locale;
};

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<footer class="bg-[#202020] px-5 text-white lg:px-20">
  <div
    class="mx-auto grid grid-cols-[310px_300px_360px] items-start gap-[76px] py-10 text-sm max-lg:grid-cols-1 max-lg:gap-7">
    <address class="m-0 text-sm leading-[1.78] font-bold not-italic">
      <strong class="mb-[18px] block uppercase">{t("footer.addressTitle")}</strong>
      <span class="mb-[12px] block">{t("footer.addressName")}</span>
      <span class="mb-[12px] block">
        {
          t("footer.addressLine")
            .split("\n")
            .map((line) => (
              <Fragment>
                {line}
                <br />
              </Fragment>
            ))
        }
      </span>
      <span class="mb-[12px] block">
        {t("footer.phoneLabel")}
        <a class="text-inherit no-underline" href={`tel:${t("footer.phone")}`}>{t("footer.phone")}</a>
      </span>
      <span class="block">
        {t("footer.emailLabel")}{" "}
        <a class="text-inherit no-underline" href="mailto:info@manastirea-saharna.md"> info@manastirea-saharna.md </a>
        <a class="text-inherit no-underline" href="mailto:secretariat@manastirea-saharna.md">
          secretariat@manastirea-saharna.md
        </a>
      </span>
    </address>
  </div>
  <div
    class="flex items-center justify-between bg-[#171717] py-5 text-neutral-500 shadow-[50vw_0_0_#171717,-50vw_0_0_#171717]">
    <p class="m-0 text-sm font-bold">{t("footer.copyright")}</p>
    <nav
      class="col-start-2 row-span-2 row-start-1 flex gap-6 font-sans text-[28px] font-bold text-neutral-300 max-sm:col-auto max-sm:row-auto max-sm:mt-3.5"
      aria-label={t("social.label")}>
      <a class="text-inherit no-underline" href="" aria-label={t("social.facebook")}>f</a>
      <a class="text-inherit no-underline" href="" aria-label={t("social.instagram")}>◎</a>
      <a class="text-inherit no-underline" href="" aria-label={t("social.youtube")}>▶</a>
    </nav>
  </div>
</footer>
