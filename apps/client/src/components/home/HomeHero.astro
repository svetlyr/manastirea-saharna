---
import type { Locale } from "@i18n";
import { useTranslations } from "@i18n/utils";

type Props = {
  lang: Locale;
};

const { lang } = Astro.props;
const t = useTranslations(lang);
const heroPosterSrc =
  "https://commons.wikimedia.org/wiki/Special:Redirect/file/Monasterio_de_Saharna%2C_Saharna%2C_Moldavia%2C_2023-11-01%2C_DD_49-51_HDR.jpg";
const heroMobileVideoSrc = "/hero/hero-monastery-720.webm";
const heroDesktopVideoSrc = "/hero/hero-monastery-1280.webm";
const heroMp4VideoSrc = "/hero/hero-monastery-1280.mp4";
---

<section
  class="church-hero relative flex min-h-[min(790px,calc(100vh_-_116px))] items-center text-white max-sm:min-h-[640px]"
  aria-label={t("home.heroLabel")}>
  <div class="hero-visual absolute inset-0 overflow-hidden" aria-hidden="true">
    <video class="hero-video" autoplay muted loop playsinline preload="metadata" poster={heroPosterSrc}>
      <source src={heroMobileVideoSrc} type="video/webm" media="(max-width: 680px)" />
      <source src={heroDesktopVideoSrc} type="video/webm" />
      <source src={heroMp4VideoSrc} type="video/mp4" />
    </video>
  </div>
  <div
    class="relative z-10 mx-auto w-[min(1120px,calc(100%_-_20px))] pt-[250px] max-sm:w-[calc(100%_-_32px)] max-sm:pt-[190px]">
    <h1
      class="font-display mb-6 max-w-[920px] text-[clamp(42px,4vw,70px)] leading-none font-bold tracking-normal uppercase">
      {t("home.heroTitle")}
    </h1>
    <p class="m-0 text-[19px] font-bold uppercase">{t("home.heroSubtitle")}</p>
  </div>
</section>
