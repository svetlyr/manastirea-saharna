---
import PrayerRequestForm from "@components/PrayerRequestForm.astro";
import type { Locale } from "@i18n";
import { useTranslations } from "@i18n/utils";

type Props = {
  lang: Locale;
};

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section
  id="pomelnic-modal"
  class="fixed inset-0 z-[80] hidden items-center justify-center bg-black/60 px-4 py-10 backdrop-blur-sm target:flex"
  aria-label={t("pomelnic.modalLabel")}>
  <a class="absolute inset-0" href="#pomelnic-form" aria-label={t("pomelnic.closeOverlay")}></a>
  <div
    class="relative max-h-[calc(100vh_-_80px)] w-full max-w-[780px] overflow-y-auto rounded-lg bg-white p-6 shadow-[0_30px_90px_rgb(0_0_0_/_35%)] md:p-8">
    <div class="mb-6 flex items-start justify-between gap-4">
      <div>
        <p class="text-gold m-0 text-sm font-bold tracking-[0.28em] uppercase">{t("pomelnic.modalEyebrow")}</p>
        <h2 class="font-display text-church-green mt-2 mb-0 text-[clamp(30px,4vw,46px)] leading-none font-bold">
          {t("pomelnic.modalTitle")}
        </h2>
      </div>
      <a
        class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-neutral-100 text-2xl leading-none text-neutral-700 no-underline transition hover:bg-neutral-200"
        href="#pomelnic-form"
        aria-label={t("pomelnic.close")}>
        ×
      </a>
    </div>
    <PrayerRequestForm idPrefix="modal-pomelnic" lang={lang} compact />
  </div>
</section>
