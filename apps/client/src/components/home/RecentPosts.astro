---
import PostCard from "@components/PostCard.astro";
import { getRecentPosts } from "@data/posts";
import type { Locale } from "@i18n";
import { getLocalizedPath, useTranslations } from "@i18n/utils";

type Props = {
  lang: Locale;
};

const { lang } = Astro.props;
const t = useTranslations(lang);
const posts = await getRecentPosts(lang);
---

{
  posts.length > 0 && (
    <section class="bg-site-gray my-10" aria-labelledby="recent-posts-title">
      <h2
        id="recent-posts-title"
        class="font-display text-church-green mb-[54px] text-center text-[44px] leading-none font-bold tracking-normal uppercase">
        {t("home.recentPosts")}
      </h2>
      <div class="mx-auto grid w-[min(1090px,calc(100%_-_20px))] grid-cols-3 gap-[60px] max-lg:grid-cols-1 max-lg:gap-7 max-sm:w-[calc(100%_-_32px)]">
        {posts.map((post) => <PostCard post={post} lang={lang} />)}
      </div>
      <div class="mt-10 flex justify-center">
        <a
          class="bg-church-green hover:bg-church-green/90 focus-visible:outline-church-green inline-flex min-h-12 items-center justify-center px-8 text-base font-bold text-white no-underline transition-colors focus-visible:outline-2 focus-visible:outline-offset-4"
          href={getLocalizedPath("/posts", lang)}>
          {t("home.allNews")}
        </a>
      </div>
    </section>
  )
}
