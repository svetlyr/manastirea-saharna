---
import PrayerRequestForm from "@components/PrayerRequestForm.astro";
import type { Locale } from "@i18n";
import { useTranslations } from "@i18n/utils";

type Props = {
  lang: Locale;
};

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="pomelnic-form" class="bg-[#f8f8f6] py-24 max-sm:py-16" aria-labelledby="pomelnic-title">
  <div
    class="mx-auto grid w-[min(1120px,calc(100%_-_20px))] grid-cols-[0.82fr_1.18fr] gap-8 max-lg:grid-cols-1 max-sm:w-[calc(100%_-_32px)]">
    <div>
      <span class="bg-gold mb-8 block h-0.5 w-[70px]"></span>
      <p class="text-gold m-0 text-sm font-bold tracking-[0.28em] uppercase">{t("pomelnic.eyebrow")}</p>
      <h2
        id="pomelnic-title"
        class="font-display text-church-green mt-4 mb-5 text-[clamp(38px,4.5vw,62px)] leading-none font-bold">
        {t("pomelnic.title")}
      </h2>
      <p class="m-0 text-lg leading-8 text-neutral-600">
        {t("pomelnic.description")}
      </p>
    </div>
    <div class="rounded-lg border border-neutral-200 bg-white p-6 shadow-[0_20px_60px_rgb(0_0_0_/_8%)] md:p-8">
      <PrayerRequestForm idPrefix="page-pomelnic" lang={lang} />
    </div>
  </div>
</section>
