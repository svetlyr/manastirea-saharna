---
import type { Locale } from "@i18n";
import { useTranslations } from "@i18n/utils";

type Props = {
  lang: Locale;
};

const { lang } = Astro.props;
const t = useTranslations(lang);
const cards = [
  { label: t("representation.moscow"), imageClass: "representation-moscow" },
  { label: t("representation.gathering"), imageClass: "representation-gathering" },
  { label: t("representation.newYork"), imageClass: "representation-new-york" },
];
---

<section class="bg-white pt-[92px] text-center" aria-labelledby="representation-title">
  <span class="bg-gold mx-auto mb-[38px] block h-0.5 w-[70px]"></span>
  <h2
    id="representation-title"
    class="font-display text-church-green mx-auto mb-9 w-[min(920px,calc(100%_-_20px))] text-[clamp(36px,3.4vw,58px)] leading-[1.16] font-bold tracking-normal">
    {t("home.representationTitle")}
  </h2>
  <span class="bg-gold mx-auto block h-0.5 w-[70px]"></span>
  <div
    class="mx-auto mt-[60px] grid w-[min(1290px,calc(100%_-_20px))] grid-cols-3 gap-[70px] max-lg:grid-cols-1 max-lg:gap-7 max-sm:w-[calc(100%_-_32px)]">
    {
      cards.map((card) => (
        <figure class="m-0">
          <div
            class={`representation-image h-[255px] border-l-[9px] border-[#49641f] ${card.imageClass}`}
            aria-hidden="true"
          />
          <figcaption class="sr-only">{card.label}</figcaption>
        </figure>
      ))
    }
  </div>
</section>
