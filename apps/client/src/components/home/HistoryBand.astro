---
import type { Locale } from "@i18n";
import { useTranslations } from "@i18n/utils";

type Props = {
  lang: Locale;
};

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="history-band relative min-h-[432px] text-center text-white">
  <div class="history-visual absolute inset-0" aria-hidden="true"></div>
  <div class="relative z-10 pt-[72px]">
    <h2
      class="font-display mb-[34px] px-0 text-[clamp(38px,3.6vw,64px)] leading-[1.22] font-bold tracking-normal opacity-75 [text-shadow:0_2px_3px_rgb(0_0_0_/_65%)] max-sm:px-5">
      {t("home.historyTitle")}
    </h2>
    <!-- <a
      class="inline-flex min-h-[38px] min-w-[132px] items-center justify-center rounded-[5px] border-2 border-white text-[19px] font-bold text-white no-underline"
      href="#">
      {t("home.readMore")}
    </a> -->
  </div>
</section>
