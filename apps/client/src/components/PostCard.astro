---
import type { PostItem } from "@data/posts";
import type { Locale } from "@i18n";
import { getLocalizedPath, useTranslations } from "@i18n/utils";

type Props = {
  lang: Locale;
  post: PostItem;
};

const { lang, post } = Astro.props;
const t = useTranslations(lang);
const href = getLocalizedPath(`/posts/${post.slug}`, lang);
---

<article
  class="group flex min-w-0 flex-col bg-white shadow-[0_0_0_1px_#dedede] transition duration-300 ease-out hover:-translate-y-1 hover:shadow-[0_16px_34px_rgb(0_0_0_/_14%)] focus-within:-translate-y-1 focus-within:shadow-[0_16px_34px_rgb(0_0_0_/_14%)]">
  <a class="block overflow-hidden no-underline" href={href} aria-label={post.title}>
    {
      post.image ? (
        <img
          class="h-[220px] w-full object-cover transition duration-500 ease-out group-hover:scale-[1.04] group-focus-within:scale-[1.04]"
          src={post.image.url}
          alt={post.image.alt}
          loading="lazy"
        />
      ) : (
        <div class="post-image h-[220px] overflow-hidden transition duration-500 ease-out group-hover:scale-[1.04] group-focus-within:scale-[1.04]" aria-hidden="true">
          <span />
        </div>
      )
    }
  </a>
  <div class="flex flex-1 flex-col px-5 pt-7 pb-8">
    <h2 class="font-display text-church-green mb-5 text-[30px] leading-[1.07] font-bold tracking-normal">
      <a class="text-inherit no-underline" href={href}>{post.title}</a>
    </h2>
    {post.date && <time class="mb-3.5 block text-lg text-neutral-500">{post.date}</time>}
    <p class="m-0 text-[19px] leading-[1.55] text-neutral-500">{post.excerpt}</p>
    <a class="text-church-green mt-auto inline-block pt-5 text-base font-bold no-underline transition-colors group-hover:text-[#f23b2f] group-focus-within:text-[#f23b2f]" href={href}>
      {t("news.readMore")}
    </a>
  </div>
</article>
