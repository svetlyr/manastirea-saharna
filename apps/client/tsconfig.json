{
    "extends": ["astro/tsconfigs/strictest", "../../tsconfig.json"],

    "files": ["../../reset.d.ts"],
    "include": ["src", "**/*.d.ts", "./*.config.ts"],
    "exclude": ["**/dist", "**/node_modules", ".git", ".github", ".vscode"],

    "compilerOptions": {
        "jsx": "react-jsx",
        "jsxImportSource": "@builder.io/qwik",

        // * Handled by eslint
        "noUnusedLocals": false,
        "noUnusedParameters": false,

        "noEmit": false,
        "composite": true,

        "baseUrl": ".",
        "paths": {
            "@i18n": ["src/i18n/index"],

            "@i18n/*": ["src/i18n/*"],
            "@data/*": ["src/data/*"],
            "@utils/*": ["src/utils/*"],
            "@assets/*": ["src/assets/*"],
            "@styles/*": ["src/styles/*"],
            "@layouts/*": ["src/layouts/*"],
            "@components/*": ["src/components/*"]
        }
    }
}
