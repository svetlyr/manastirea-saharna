PAYLOAD_SECRET=replace-with-a-long-random-secret
# Neon pooled Postgres connection string. Use the pooled URL for serverless/free hosts.
DATABASE_URI=postgresql://user:password@ep-example-pooler.region.aws.neon.tech/database?sslmode=require
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001

# Used by the seed script only.
PAYLOAD_SEED_ADMIN_EMAIL=admin@example.com
PAYLOAD_SEED_ADMIN_PASSWORD=change-me-long-password

# Cloudflare R2 / S3-compatible media storage.
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://media.example.com

